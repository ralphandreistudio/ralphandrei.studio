# Your live site URL (no trailing slash) — used for Facebook/Messenger link previews and sitemap.
# Set in Vercel: Project → Settings → Environment Variables → Production → VITE_SITE_URL
# (Strongly recommended.) If omitted, the build uses VERCEL_PROJECT_PRODUCTION_URL, not the
# per-deployment VERCEL_URL (which can break og:image for Facebook).
VITE_SITE_URL=https://ralphandrei-studio.vercel.app
